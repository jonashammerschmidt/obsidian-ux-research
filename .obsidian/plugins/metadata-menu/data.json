{
  "presetFields": [
    {
      "id": "task",
      "name": "task",
      "type": "File",
      "path": "",
      "options": {
        "dvQueryString": "dv.pages('\\\"01 Story Nodes\\\"').where(p => (p.entity_type ?? \"\").toLowerCase() === \"task\")",
        "customRendering": "`${((page.entity_type ?? \"task\") + \"\").toUpperCase()}: ${(page.title ?? page.file.name).replace(/^(?:\\d+\\s*-\\s*)?Task\\\\s*-\\\\s*/i, \"\")}`",
        "customSorting": "(a.basename ?? \"\").localeCompare(b.basename ?? \"\")"
      }
    },
    {
      "id": "painpoint_cluster",
      "name": "painpoint_cluster",
      "type": "File",
      "path": "",
      "options": {
        "dvQueryString": "dv.pages().where(p => (p.entity_type ?? \"\").toLowerCase() === \"painpoint_cluster\")",
        "customRendering": "`${((page.entity_type ?? \"painpoint_cluster\") + \"\").replace(/_/g, \" \").toUpperCase()}: ${(page.title ?? page.file.name).replace(/^Painpoint Cluster\\s*-\\s*/i, \"\")}`",
        "customSorting": "(a.basename ?? \"\").localeCompare(b.basename ?? \"\")"
      }
    },
    {
      "id": "solves",
      "name": "solves",
      "type": "Multi",
      "path": "",
      "options": {
        "sourceType": "ValuesFromDVQuery",
        "valuesList": {},
        "valuesFromDVQuery": "dv.pages().where(p => (p.entity_type ?? \"\").toLowerCase() === \"painpoint\").sort(p => p.file.name, 'asc').map(p => `[[${p.file.name.replace(/\\\\.md$/, \"\")}]]`)"
      }
    },
    {
      "id": "focus_painpoint",
      "name": "focus_painpoint",
      "type": "File",
      "path": "",
      "options": {
        "dvQueryString": "dv.pages().where(p => (p.entity_type ?? \"\").toLowerCase() === \"painpoint\").map(p => p.file)",
        "customRendering": "(page.title ?? page.file.name).replace(/^Painpoint\\\\s*-\\\\s*/i, \"\")",
        "customSorting": "(a.basename ?? \"\").localeCompare(b.basename ?? \"\")"
      }
    },
    {
      "id": "relationship_scope",
      "name": "relationship_scope",
      "type": "Select",
      "path": "",
      "options": {
        "sourceType": "ValuesList",
        "valuesList": {
          "1": "all",
          "2": "focus"
        }
      }
    },
    {
      "id": "sort_direction",
      "name": "sort_direction",
      "type": "Select",
      "path": "",
      "options": {
        "sourceType": "ValuesList",
        "valuesList": {
          "1": "asc",
          "2": "desc"
        }
      }
    },
    {
      "id": "show_empty_tasks",
      "name": "show_empty_tasks",
      "type": "Boolean",
      "path": "",
      "options": {}
    },
    {
      "id": "show_painpoints",
      "name": "show_painpoints",
      "type": "Boolean",
      "path": "",
